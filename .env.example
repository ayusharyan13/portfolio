[TEMPLATE]
# ─── Frontend API URL (for Vercel/Cloudflare Workers deployment) ───
# Set this to your Cloudflare Worker URL when deploying on Vercel.
# Local dev uses http://localhost:8001 automatically.
# VITE_API_URL=https://portfolio-chatbot.your-subdomain.workers.dev

# ─── LLM Provider (choose one) ───
# Set LLM_PROVIDER to: openai | gemini | groq | custom
# Default is set in wrangler.toml (currently: groq)

# ─── Groq Cloud (used for chat LLM) ───
# Fast, free tier: 30 req/min. Get key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
# Optional: groq model override (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# ─── OpenAI (used for embeddings - still required!) ───
# Even if using Groq for chat, OpenAI is needed for text embeddings (RAG retrieval)
# Costs ~$0.02 per million tokens. Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
# Optional: embedding model override (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small

# ─── Google Gemini (alternative LLM provider) ───
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash

# ─── Custom OpenAI-compatible provider (e.g., Ollama) ───
# CUSTOM_API_BASE_URL=http://localhost:11434/v1
# CUSTOM_API_KEY=optional_api_key
# CUSTOM_MODEL=gpt-4o-mini

# ─── Generation params (optional overrides) ───
# MAX_TOKENS=512
# TEMPERATURE=0.7
